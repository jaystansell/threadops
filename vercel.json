{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/docs-notify",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/purge-files",
      "schedule": "0 3 * * *"
    }
  ]
}

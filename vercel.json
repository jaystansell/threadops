{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/docs-notify",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/purge-files",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/update-pricing",
      "schedule": "0 8 1 * *"
    },
    {
      "path": "/api/cron/webhook-reminders",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/check-unhandled",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/check-ack-timeouts",
      "schedule": "* * * * *"
    }
  ]
}
